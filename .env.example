# Supabase
# 注意：SUPABASE_URL 與 SUPABASE_KEY 由 @nuxtjs/supabase 模組直接讀取，不需 NUXT_ 前綴
SUPABASE_URL=https://ovppylewvgkezwmcsmgn.supabase.co
SUPABASE_KEY=your-anon-key
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
NUXT_OPENAI_API_KEY=sk-...

# 索引檢查（JSON 字串陣列）
NUXT_SERP_API_KEYS=["key1","key2"]
NUXT_APIFY_KEYS=["key1"]
NUXT_SCRAPER_API_KEYS=["key1"]

# Google PageSpeed Insights
NUXT_PAGESPEED_API_KEY=AIza...

# 應用程式限制
NUXT_APP_DAILY_DOMAIN_LIMIT=5
NUXT_APP_MAX_PAGES_PER_RUN=30

# 全站分析設定
NUXT_DOMAIN_CACHE_TTL_HOURS=24
NUXT_SITE_INDEXING_ENABLED=true
